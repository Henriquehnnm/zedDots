{
  "collaboration_panel": {
    "button": false
  },
  "search": {
    "button": false
  },
  "terminal": {
    "shell": {
      "program": "fish"
    }
  },
  "ui_font_family": "Fira Sans",
  "auto_indent": true,
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 16,
  "buffer_line_height": {
    "custom": 1.9
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "drag_and_drop_selection": {
    "enabled": false
  },
  "git": {
    "git_gutter": "hide"
  },
  "theme": "GitHub Dark",
  "icon_theme": "Base Charmed Icons",
  "helix_mode": true,
  "current_line_highlight": "none",
  "disable_ai": true,

