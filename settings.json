{
  "collaboration_panel": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "terminal": {
    "shell": {
      "program": "fish",
    },
  },
  "ui_font_family": "Fira Sans",
  "auto_indent": true,
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 16,
  "buffer_line_height": {
    "custom": 1.9,
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "git": {
    "git_gutter": "hide",
  },
  "theme": "One Dark",
  "icon_theme": "Base Charmed Icons",
  "helix_mode": true,
  "current_line_highlight": "none",
  "disable_ai": true,

  "theme_overrides": {
    "One Dark": {
      "border": "#282c33",
      "border.variant": "#282c33",
      "border.focused": "#282c33",
      "title_bar.background": "#282c33",
      "title_bar.inactive_background": "#282c33",
      "status_bar.background": "#282c33",
      "tab_bar.background": "#282c33",
      "panel.background": "#282c33",
      "tab.inactive_background": "#282c33",
      "background": "#282c33",
      "tab.active_background": "#333943",
      "editor.document_highlight.bracket_background": "#0000",
    },
  },

  "title_bar": {
    "show_sign_in": false,
    "show_user_picture": false,
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_menu": false,
  },

  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
    "show_pinned_tabs_in_separate_row": false,
  },

  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
  },

  "status_bar": {
    "active_encoding_button": "disabled",
    "active_language_button": false,
    "cursor_position_button": false,
    "line_endings_button": false,
  },

  "project_panel": {
    "button": true,
    "dock": "right",
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },

  "scrollbar": {
    "show": "never",
  },

  "indent_guides": {
    "enabled": false,
  },

  "gutter": {
    "min_line_number_digits": 0,
    "runnables": false,
  },
}
